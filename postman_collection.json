              "path": ["approval", "list"],
              "query": [
                {
                  "key": "type",
                  "value": "LEAVE",
                  "description": "申请类型: LEAVE, EXPENSE, PURCHASE"
                },
                {
                  "key": "status",
                  "value": "PENDING",
                  "description": "状态: COMPLETED, PENDING, REJECTED, CANCELLED, IN_PROGRESS"
                },
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "开始日期"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "description": "结束日期"
                },
                {
                  "key": "userId",
                  "value": "",
                  "description": "用户ID（可选）",
                  "disabled": true
                }
              ]
            },
            "description": "获取审批列表，支持多种筛选条件"
