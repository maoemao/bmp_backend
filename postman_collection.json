        {
          "name": "Get Approval List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/approval/list?type=LEAVE&status=PENDING&startDate=2024-01-01&endDate=2024-12-31",
